# ✅ 1. СНАЧАЛА ловим нажатия кнопок
@dp.message(F.text == "💰 График расходов")
async def expenses_func(message: types.Message):
    user_id = message.from_user.id
    file_path = get_user_file_path(user_id, "expense")

    if not os.path.exists(file_path):
        await message.answer("📭 Нет данных для построения графика.")
        return

    df = load_or_create_df(file_path)
    if df.empty:
        await message.answer("📭 Таблица пуста. Добавьте расходы.")
        return

    df["Дата"] = pd.to_datetime(df["Дата"])
    df = df.sort_values("Дата")
    pivot_df = df.pivot_table(index="Затраты", columns="Дата", values="Деньги", aggfunc="sum")

    if pivot_df.empty:
        await message.answer("📭 Недостаточно данных.")
        return

    plt.figure(figsize=(10, 6))
    for category in pivot_df.index:
        plt.plot(pivot_df.columns, pivot_df.loc[category], marker='o', linestyle='-', linewidth=2, label=category)

    plt.xlabel('Дата')
    plt.ylabel('Затраты (руб)')
    plt.title('📊 График затрат по дням')
    plt.legend(loc='upper left', bbox_to_anchor=(1, 1))
    plt.grid(True, alpha=0.3)
    plt.xticks(rotation=45, ha='right')
    plt.tight_layout()

    buffer = BytesIO()
    plt.savefig(buffer, format='png', dpi=120, bbox_inches='tight')
    buffer.seek(0)
    plt.close()

    await message.answer_photo(
        photo=BufferedInputFile(buffer.getvalue(), filename="expenses_plot.png"),
        caption="📈 Ваш график готов"
    )

